{
  "id": "com.torrao.athom",
  "name": "ATHOM - Rede de Pensamentos",
  "short_name": "ATHOM",
  "description": "Compartilhe pensamentos, músicas e momentos com amigos.",
  "start_url": "/",
  "display": "standalone",
  "background_color": "#121212",
  "theme_color": "#8b1031",
  "orientation": "portrait",
  "lang": "pt-BR",
  "dir": "ltr",
  "scope": "/",
  "prefer_related_applications": false,
  "categories": ["social", "lifestyle"],
  "iarc_rating_id": "0",
  "icons": [
    {
      "src": "/assets/images/icon-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/assets/images/icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/assets/images/icon-512-maskable.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "maskable"
    }
  ],
  "screenshots": [
    {
      "src": "screenshot1.png",
      "sizes": "1080x1920",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "Tela de login do ATHOM"
    },
    {
      "src": "screenshot2.png",
      "sizes": "1080x1920",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "Feed Now com pensamentos"
    }
  ],
  "shortcuts": [
    {
      "name": "Novo Pensamento",
      "short_name": "Publicar",
      "description": "Crie um novo pensamento",
      "url": "/?action=post",
      "icons": [
        { "src": "/assets/images/icone-post.png", "sizes": "96x96" }
      ]
    },
    {
      "name": "Meu Perfil",
      "short_name": "Perfil",
      "url": "/?action=profile",
      "icons": [
        { "src": "/assets/images/icone-perfil.png", "sizes": "96x96" }
      ]
    },
    {
      "name": "Conversas (Textz)",
      "short_name": "Textz",
      "description": "Abrir o chat",
      "url": "/?tab=textz"
    }
  ],
  "share_target": {
    "action": "/?share=1",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url",
      "files": [
        {
          "name": "media",
          "accept": ["image/*", "video/*"]
        }
      ]
    }
  },
  "protocol_handlers": [
    {
      "protocol": "web+you",
      "url": "/?protocol=%s"
    }
  ],
  "display_override": ["standalone", "minimal-ui"],
  "launch_handler": {
    "client_mode": "auto"
  },
  "edge_side_panel": {},
  "window_controls_overlay": true,
  "file_handlers": [
    {
      "action": "/?open=1",
      "accept": {
        "text/plain": [".txt", ".md"],
        "image/png": [".png"],
        "image/jpeg": [".jpg", ".jpeg"]
      }
    }
  ],
  "note_taking": {
    "new_note_url": "/?note=new"
  },
  "related_applications": []
}        "image/jpeg": [".jpg", ".jpeg"]
      }
    }
  ],
  "note_taking": {
    "new_note_url": "index.html?note=new"
  }
}
